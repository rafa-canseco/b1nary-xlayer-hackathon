# --- Required ---
MM_PRIVATE_KEY=0x...               # MM wallet private key for EIP-712 signing
MM_API_KEY=mm-key-...              # API key for /mm/* endpoints
BACKEND_URL=http://localhost:8000  # b1nary API base URL
RPC_URL=https://sepolia.base.org   # Base RPC for reading makerNonce

# --- Optional (defaults shown) ---
REFRESH_INTERVAL=60                # Seconds between quote refresh cycles
SPREAD_BPS=200                     # Spread in basis points (200 = 2%)
MAX_AMOUNT=10000000000             # Max oTokens per quote (8 decimals, 100 ETH)
DEADLINE_SECONDS=300               # Quote deadline duration
CHAIN_ID=84532                     # Chain ID for EIP-712 domain
BATCH_SETTLER=0x29bb32c014aC3378FfbE335804B94cED48f2afc4  # BatchSettler address
RISK_FREE_RATE=0.05                # Annualized risk-free rate for BS pricing

# --- Capacity ---
MM_TYPE=internal                   # internal (full reporting) | external (minimal)
CAPACITY_RESERVE_RATIO=0.25        # Reserve buffer on hedge pool (0.25 = 25%)
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913  # Base mainnet USDC
MARGIN_POOL_ADDRESS=0xa1e04873F6d112d84824C88c9D6937bE38811657  # Base mainnet MarginPool

# --- Railway environments ---
# Staging (dev branch):
#   BACKEND_URL=https://optionsprotocolbackend-staging.up.railway.app
#   CHAIN_ID=84532 (Base Sepolia)
#   RPC_URL=https://lb.drpc.live/base-sepolia/<DRPC_KEY>
#
# Production (main branch):
#   BACKEND_URL=https://api.b1nary.app
#   CHAIN_ID=8453 (Base Mainnet)
#   RPC_URL=https://lb.drpc.live/base/<DRPC_KEY>
