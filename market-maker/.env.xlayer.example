# XLayer Hackathon Config
# Copy this to .env locally. Never commit real keys.

# Required
MM_PRIVATE_KEY=0x...
MM_API_KEY=mm-key-...
BACKEND_URL=http://localhost:8000
RPC_URL=https://sepolia.base.org

# Base chain fallback config
CHAIN_ID=84532
BATCH_SETTLER=
ASSETS=

# XLayer chain
XLAYER_RPC_URL=https://testrpc.xlayer.tech
XLAYER_CHAIN_ID=1952
XLAYER_BATCH_SETTLER=0x6aea5B95d64962E7F001218159cB5fb11712E8B1
XLAYER_USDC_ADDRESS=0x4A881f3f745B99f0C5575577D80958a5a16b7347
XLAYER_MARGIN_POOL_ADDRESS=0x3b14faD41CcbD471296e11Ea348dC303aA3A4156
XLAYER_ASSETS=okb

# Common
REFRESH_INTERVAL=15
SPREAD_BPS=200
MAX_AMOUNT=10000000000
DEADLINE_SECONDS=300
RISK_FREE_RATE=0.05

# Hedging
HEDGE_MODE=simulate
HYPERLIQUID_TESTNET=true
