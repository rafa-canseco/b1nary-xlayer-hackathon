# =============================================================
# Options Protocol — X Layer Mainnet Deploy
# =============================================================

# --- RPC ---
XLAYER_MAINNET_RPC_URL=https://rpc.xlayer.tech
CHAIN_LABEL="X Layer Mainnet"

# --- Signer ---
# Use one of:
#   1. PRIVATE_KEY=0x...
#   2. FOUNDRY_ACCOUNT=deployer and DEPLOYER_ADDRESS=0x...
#   3. USE_LEDGER=true and DEPLOYER_ADDRESS=0x...
DEPLOYER_ADDRESS=
PRIVATE_KEY=
FOUNDRY_ACCOUNT=
USE_LEDGER=false
LEDGER_HD_PATH=

# --- Operator / MM ---
OPERATOR_ADDRESS=
MM_ADDRESS=

# --- Treasury ---
TREASURY_ADDRESS=

# --- Tokens ---
XETH_ADDRESS=0xe7b000003a45145decf8a28fc755ad5ec5ea025a
USDT0_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736
XETH_DECIMALS=18
USDT0_DECIMALS=6

# --- Oracle ---
CHAINLINK_ETH_USD_FEED=0x8b85b50535551f8e8cdaf78da235b5cf1005907b

# --- Physical delivery ---
AAVE_POOL_ADDRESS=0xe3f3caefdd7180f884c01e57f65df979af84f116
UNISWAP_SWAP_ROUTER=0x4f0c28f5926afda16bf2506d5d9e57ea190f9bca
UNISWAP_V3_FACTORY=0x4b2ab38dbf28d31d467aa8993f6c2585981d6804
XETH_USDT0_POOL=0x77ef18adf35f62b2ad442e4370cdbc7fe78b7dcc
SWAP_FEE_TIER=500

# --- MarginPool Aave yield ---
# Keep disabled for the hackathon demo. BatchSettler still uses Aave flash loans
# through AAVE_POOL_ADDRESS above; this section is only for idle collateral yield.
CONFIGURE_MARGIN_POOL_AAVE=false
ENABLE_MARGIN_POOL_AAVE=false
A_XETH_ADDRESS=0xe6639ba6c1d79be6d4c776e4c17504538d1719cd
A_USDT0_ADDRESS=0xf356ae412db5df43bd3a10746f7ad4e1c4de4297
YIELD_RECIPIENT=

# --- Protocol config ---
PROTOCOL_FEE_BPS=400
PRICE_DEVIATION_THRESHOLD_BPS=1000
MAX_ORACLE_STALENESS=3600
ESCAPE_DELAY=259200

# --- Post-deploy ---
VERIFY_CONTRACTS=false
