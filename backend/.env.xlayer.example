MOCK_CHAINLINK_FEED_ADDRESS=0x0A56056Af2e1157B0787E50B4214d21fB9e7fd5a

# XLayer protocol contracts
XLAYER_BATCH_SETTLER_ADDRESS=0x6aea5B95d64962E7F001218159cB5fb11712E8B1
XLAYER_CONTROLLER_ADDRESS=0x75701c1A79Ea45F8BDE9A885A84a7581672d4820
XLAYER_OTOKEN_FACTORY_ADDRESS=0x7C9418a13462174b2b29bc0B99807A13B9731690
