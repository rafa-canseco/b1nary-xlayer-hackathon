# XLayer Hackathon backend config.
# Copy to backend/.env for local runs or set these variables in Railway.
# Never commit real private keys or service-role keys.

# Supabase project for the hackathon database
SUPABASE_URL=https://yjvmvafjxeatmcolaoik.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Runtime mode
BETA_MODE=true
CHAIN_ID=1952
ALLOWED_ORIGINS=*
API_BASE_URL=

# XLayer testnet RPC
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_WSS_RPC_URL=
XLAYER_CHAIN_ID=1952

# Operator wallet used by faucet, oToken manager, price updater, and bots.
# Store only in Railway/local .env. Do not paste into Linear or docs.
OPERATOR_PRIVATE_KEY=

# XLayer mock assets and oracle
WOKB_ADDRESS=0x1B5D20CcA8D0B8F5FB25aA06735a57E1B104A1A8
XLAYER_USDC_ADDRESS=0x4A881f3f745B99f0C5575577D80958a5a16b7347
